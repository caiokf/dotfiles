{
  "cSpell.language": "en,en-GB,en-US,ru",
  "cSpell.showStatus": false,
  "cSpell.diagnosticLevel": "Hint",
  "debug.allowBreakpointsEverywhere": true,
  "editor.accessibilitySupport": "on",
  "editor.codeLens": true,
  "editor.colorDecorators": true,
  "editor.dragAndDrop": false,
  "editor.folding": true,
  "editor.fontFamily": "Fira Code",
  "editor.fontLigatures": true,
  "editor.fontSize": 13,
  "editor.glyphMargin": true,
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "all",
  "editor.rulers": [80],
  "editor.scrollBeyondLastLine": false,
  //"editor.snippetSuggestions": "none",
  "editor.cursorSurroundingLines": 3,
  "editor.useTabStops": true,
  "editor.formatOnPaste": false,
  "editor.tabCompletion": "on",
  "editor.wordWrap": "on",
  "editor.wordWrapColumn": 80,
  "explorer.confirmDelete": false,
  "explorer.decorations.badges": false,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    ".babelrc": "jsonc",
    ".eslintrc": "jsonc",
    "*.pyi": "python",
    "zshrc": "shellscript",
    ".aliases": "shellscript",
    ".exports": "shellscript",
    ".prompt": "shellscript",
    ".functions": "shellscript",
    "bash_profile": "shellscript",
    "editorconfig": "yaml",
    "Fastfile": "ruby",
    "Deliverfile": "ruby",
    "Appfile": "ruby",
    "Matchfile": "ruby",
    "*.djson": "json",
  },
  "files.autoSave": "onFocusChange",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.cache": true,
    "**/.coverage": true,
    "**/.DS_Store": true,
    "**/.idea": true,
    "**/.mypy_cache": true,
    "**/.pytest_cache": true,
    "**/.venv": true,
    "**/*.py[co]": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/.dist": true,
    "**/.git": true,
    "**/.turbo": true,
    "**/.nx": true,
    "**/.nuxt": true,
    "**/.output": true
  },
  "git.autofetch": false,
  "python.formatting.provider": "none",
  "python.terminal.activateEnvironment": true,
  "python.workspaceSymbols.enabled": true,
  "telemetry.enableCrashReporter": false,
  "telemetry.enableTelemetry": false,
  "terminal.integrated.env.osx": {
    "SOBOLE_THEME_MODE": "dark",
  },
  "window.clickThroughInactive": false,
  "window.newWindowDimensions": "maximized",
  "workbench.colorCustomizations": {
    "gitDecoration.modifiedResourceForeground": "#d4cb68",
    "activityBar.activeBorder": "#e5b358",
    "editorSuggestWidget.highlightForeground": "#e5b358",
    "editorSuggestWidget.selectedBackground": "#1c2a42",
  },
  "workbench.editor.labelFormat": "short",
  "workbench.startupEditor": "newUntitledFile",
  "workbench.statusBar.visible": true,
  "workbench.tree.renderIndentGuides": "none",
  "workbench.tips.enabled": false,
  "python.linting.enabled": false,
  "git.showInlineOpenFileAction": false,
  "git.autorefresh": true,
  "git.decorations.enabled": true,
  "typescript.updateImportsOnFileMove.enabled": "never",
  "javascript.suggest.autoImports": false,
  "typescript.suggest.autoImports": false,
  "vetur.completion.autoImport": false,
  "vetur.experimental.templateInterpolationService": true,
  "breadcrumbs.enabled": true,
  "go.formatTool": "goimports",
  "javascript.updateImportsOnFileMove.enabled": "always",

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[shellscript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "files.eol": "\n",
  },
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python3",
  "workbench.editor.wrapTabs": false,
  "workbench.iconTheme": "vscode-great-icons",
  "workbench.colorTheme": "One Dark Pro Monokai Darker",
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb",
    "*.bpmn": "bpmn-io.bpmnEditor",
  },
  "window.zoomLevel": 1,
  "redhat.telemetry.enabled": false,
  "dart.flutterSdkPath": "/Users/caiokf/development/flutter",
  "[dart]": {
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [120],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
  },
  "dart.openDevTools": "flutter",
  "yaml.customTags": [
    "!And",
    "!And sequence",
    "!If",
    "!If sequence",
    "!Not",
    "!Not sequence",
    "!Equals",
    "!Equals sequence",
    "!Or",
    "!Or sequence",
    "!FindInMap",
    "!FindInMap sequence",
    "!Base64",
    "!Join",
    "!Join sequence",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!Sub sequence",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!ImportValue sequence",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Split sequence",
  ],
  "yaml.validate": false,
  "explorer.compactFolders": false,
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml",
  },
  "accessibility.signals.terminalBell": {
    "sound": "on",
  },
  "terminal.integrated.enableVisualBell": true,
  "github.copilot.editor.enableAutoCompletions": true,
  "jestrunner.debugOptions": {},
  "debug.javascript.defaultRuntimeExecutable": {
    "pwa-node": "node"
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js, ${capture}.spec.ts, ${capture}.test.ts"
  },
  "mise.binPath": "/Users/caiokf/.local/bin/mise",
  "custom-ui-style.stylesheet": {
    ".anysphere-markdown-container-root": "font-family: 'Fira Code', monospace !important; font-size: 12px !important;",
    ".aislash-editor-input": "font-family: 'Fira Code', monospace !important; font-size: 12px !important;",
    ".markdown-block-code *": "font-family: 'Fira Code', monospace !important; font-size: 12px !important;",
    ".aichat-code-block-anysphere": "font-family: 'Fira Code', monospace !important; font-size: 12px !important;",
    ".composer-message-codeblock .monaco-editor": "font-family: 'Fira Code', monospace !important; font-size: 12px !important;"
  },
  "mssql.connectionGroups": [
    {
      "name": "ROOT",
      "id": "16147157-74F7-4592-A597-ECA695D37415"
    }
  ],
  "mssql.connections": [],
  "cursor.composer.shouldChimeAfterChatFinishes": false,
  "github.copilot.nextEditSuggestions.enabled": true,
  "explorer.confirmDragAndDrop": false,
  "accessibility.signals.chatEditModifiedFile": {
    "sound": "off"
  },
  "accessibility.signals.chatRequestSent": {
    "sound": "off",
    "announcement": "off"
  },
  "accessibility.signals.chatResponseReceived": {
    "sound": "off"
  },
  "accessibility.signalOptions.volume": 0,
  "docker.extension.enableComposeLanguageServer": false,
  "json.schemaDownload.trustedDomains": {
    "https://schemastore.azurewebsites.net/": true,
    "https://raw.githubusercontent.com/": true,
    "https://www.schemastore.org/": true,
    "https://json.schemastore.org/": true,
    "https://json-schema.org/": true,
    "https://biomejs.dev": true
  },
  "codium.git.showCommitNotification": false,
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "claudeCode.allowDangerouslySkipPermissions": true,
  "claudeCode.initialPermissionMode": "bypassPermissions",
  "claudeCode.useTerminal": true,
  "claudeCode.claudeProcessWrapper": "cc",
  "claudeCodeGui.permissions.yoloMode": true,
  "claudeCodeGui.claude.executable": "cc",
  "claudeCodeGui.thinking.intensity": "think-harder",
  "vscode-cc.commandArgs": ["--dangerously-skip-permissions"],
  "vscode-cc.environmentVariables": {
    "ENABLE_BACKGROUND_TASKS": "1"
  },
  "workbench.productIconTheme": "a-file-icon-vscode-product-icon-theme"
}
